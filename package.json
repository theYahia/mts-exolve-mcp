{
  "name": "@theyahia/mts-exolve-mcp",
  "version": "1.1.0",
  "description": "MCP server for MTS Exolve API — SMS, calls, balance, numbers, call history. 6 tools.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "mts-exolve-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "smithery.yaml",
    ".claude"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "dev:http": "tsx src/index.ts --http",
    "start": "node dist/index.js",
    "start:http": "node dist/index.js --http",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build && npm test"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.1.1"
  },
  "publishConfig": {
    "access": "public"
  },
  "mcpName": "io.github.theYahia/mts-exolve-mcp",
  "keywords": [
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "claude",
    "ai",
    "russian-api",
    "mts",
    "exolve",
    "sms",
    "telephony",
    "balance",
    "call-history"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/theYahia/mts-exolve-mcp.git"
  },
  "homepage": "https://github.com/theYahia/mts-exolve-mcp#readme",
  "author": "theYahia (https://github.com/theYahia)"
}
